{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event",
  "description": "One wire event.\n\nEvery JSONL line in a Battle Lab log is one of these. The envelope\nfields are closed (`deny_unknown_fields`); per-event extensions go\ninside `data.x.*`.",
  "type": "object",
  "properties": {
    "cause": {
      "description": "`seq` of an earlier event in the same `(sessionId, origin)` that\ncausally produced this one.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "encounterId": {
      "description": "Present iff this event occurred within an active encounter.",
      "type": [
        "string",
        "null"
      ]
    },
    "origin": {
      "description": "Producer provenance: `\"server\"` or `\"client:<playerLocalId>\"`.",
      "type": "string"
    },
    "seq": {
      "description": "Monotonically increasing counter, unique within `(sessionId, origin)`.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "sessionId": {
      "description": "Stable per producer process; new on each game launch.",
      "type": "string"
    },
    "ts": {
      "description": "ISO-8601 UTC timestamp with millisecond precision.",
      "type": "string",
      "format": "date-time"
    },
    "v": {
      "description": "Schema version, fixed at `\"1.0\"` for this revision.",
      "type": "string"
    },
    "worldId": {
      "description": "Stable identifier of the Terraria world / game instance.",
      "type": "string"
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "data": {
          "$ref": "#/$defs/SessionStartData"
        },
        "type": {
          "type": "string",
          "const": "session.start"
        }
      },
      "required": [
        "type",
        "data"
      ]
